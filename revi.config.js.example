// This file defines routes and settings for prerendering your SPA.
// ──────────────────────────────────────────────────────────────

// Copy this file to your project root and rename to 'revi.config.js'

export default {
  // ── Routes ───────────────────────────────────────────────────────────────
  // List all paths you want prerendered. ReviJs will load each route
  // in a headless browser and capture the full HTML output.
  routes: [
    '/',
    '/about',
    '/pricing',
    '/blog',
    '/blog/post-1',
    '/blog/post-2',
  ],

  // ── Engine ───────────────────────────────────────────────────────────────
  // 'browser'  — Standard headless Chromium. Works for most projects (default).
  // 'advanced' — Like browser mode, but also scrolls and adds a
  //              <meta name="x-prerendered-by" content="revijs"> tag.
  // 'ssr'      — Minimal-wait mode, for frameworks with built-in SSR.
  engine: 'browser',

  // ── Output ───────────────────────────────────────────────────────────────
  // Folder where prerendered HTML is saved. Deploy or merge with your SPA build.
  outputDir: 'dist-prerendered',

  // Location of your built SPA. Run `npm run build` first, then `npx revijs`.
  distDir: 'dist',

  // ── Timing ──────────────────────────────────────────────────────────────
  // Milliseconds to wait AFTER network idle before capturing HTML.
  // Increase if your app uses animations or delayed data fetching.
  waitFor: 1200,

  // ── Browser ─────────────────────────────────────────────────────────────
  // true  — Browser runs in the background (recommended for CI/production).
  // false — Opens a visible browser window (helpful for debugging).
  headless: true,

  // ── Server ──────────────────────────────────────────────────────────────
  // Preferred local port for the temporary server.
  // ReviJs auto-increments if the port is busy.
  port: 4173,
};
