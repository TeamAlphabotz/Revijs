// revi.config.js
export default {
  // Routes to prerender. Or use sitemapInput to read from a sitemap.
  routes: ['/', '/about', '/blog/post-1'],

  // 'browser' | 'advanced' | 'ssr'
  engine: 'browser',

  // Output directory for prerendered HTML files
  outputDir: 'dist-prerendered',

  // Your built SPA directory
  distDir: 'dist',

  // --- Smart wait strategy (pick one) ---
  // Option 1: fixed delay after network idle (default)
  waitFor: 1200,

  // Option 2: wait for window.__REVI_READY__ = true in your app
  readyFlag: false,

  // Option 3: wait for a specific DOM element to appear
  waitForSelector: null, // e.g. '#app[data-loaded]'

  // --- Route sources (pick one) ---
  // Read routes from a sitemap (supports sitemap-index.xml)
  sitemapInput: null, // e.g. './sitemap-index.xml' or 'https://site.com/sitemap.xml'

  // Auto-discover routes from dist/ folder
  autoDiscover: false,

  // --- Output options ---
  // Inject missing og:title, og:description, og:image meta tags
  injectMeta: true,

  // Generate sitemap.xml in outputDir after prerendering
  sitemap: false, // or set to your base URL: 'https://yoursite.com'

  // Run SEO score check on each page after rendering
  score: true,

  // Number of routes to render in parallel
  parallel: 1,

  // Browser settings
  headless: true,
  port: 4173,
  debug: false,
};
